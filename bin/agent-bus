#!/usr/bin/env bash
# agent-bus — dependency-free helper for the Agent Bus Protocol.
set -euo pipefail

BUS="${AGENT_BUS_DIR:-$PWD/.agent-bus}"
ME="${AGENT_BUS_AGENT:-}"
SESSION="${AGENT_BUS_SESSION:-}"

die() { printf 'agent-bus: %s\n' "$*" >&2; exit 1; }
now() { date -u +%Y-%m-%dT%H:%M:%SZ; }
id_now() { date -u +%Y-%m-%dT%H%M%S; }
random_suffix() { od -An -N4 -tx4 /dev/urandom | tr -d '[:space:]'; }
need_me() { [[ "$ME" =~ ^[a-z][a-z0-9-]*$ ]] || die 'set AGENT_BUS_AGENT to a lowercase agent name'; }
need_agent() { [[ "$1" =~ ^[a-z][a-z0-9-]*$ ]] || die "invalid agent name: $1"; }
frontmatter_value() {
  awk -v wanted="$2" '
    NR == 1 && $0 == "---" { in_frontmatter = 1; next }
    in_frontmatter && $0 == "---" { exit }
    in_frontmatter {
      key = $0; sub(/:.*/, "", key)
      if (key == wanted) { value = $0; sub(/^[^:]*:[[:space:]]*/, "", value); print value; exit }
    }
  ' "$1"
}
message_path() { printf '%s/%s/inbox' "$BUS" "$1"; }

cmd_init() {
  [[ $# -gt 0 ]] || die 'usage: agent-bus init <agent> [agent...]'
  mkdir -p "$BUS/locks"
  local agent
  for agent in "$@"; do
    need_agent "$agent"
    mkdir -p "$BUS/$agent/inbox" "$BUS/$agent/processed"
  done
  printf 'initialized bus: %s\n' "$BUS"
}

ring_doorbell() {
  local to="$1" type="$2" slug="$3"
  [[ -n "${AGENT_BUS_DOORBELL:-}" ]] || return 0
  [[ -x "$AGENT_BUS_DOORBELL" ]] || die "doorbell is not executable: $AGENT_BUS_DOORBELL"
  "$AGENT_BUS_DOORBELL" "$to" "$type" "$slug"
}

cmd_send() {
  need_me
  local to="${1:?usage: agent-bus send <to> <type> <slug> [--now] [--ack] [--re <id>] [--deadline <UTC>]}"
  local type="${2:?missing type}" slug="${3:?missing slug}"; shift 3
  need_agent "$to"
  [[ -d "$(message_path "$to")" ]] || die "unknown recipient: $to (run init first)"
  case "$type" in request|delegate|status|blocker|result|ack|nack|info) ;; *) die "invalid message type: $type";; esac
  slug="$(printf '%s' "$slug" | tr '[:upper:] ' '[:lower:]-' | tr -cd 'a-z0-9-')"
  [[ -n "$slug" ]] || die 'slug became empty'
  local priority=next requires_ack=false re='' deadline=''
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --now) priority=now;; --ack) requires_ack=true;;
      --re) re="${2:?missing reply id}"; shift;;
      --deadline) deadline="${2:?missing deadline}"; shift;;
      *) die "unknown option: $1";;
    esac
    shift
  done
  local body
  body="$(cat)"
  [[ -n "$body" ]] || die 'empty message body'
  local id="$(id_now)-$ME-$type-$slug-$(random_suffix)"
  local inbox; inbox="$(message_path "$to")"
  local final="$inbox/$id.md" tmp
  tmp="$(mktemp "$inbox/.${id}.tmp.XXXXXX")" || die 'cannot create temporary message'
  {
    printf '%s\n' '---'
    printf 'id: %s\nfrom: %s\nto: %s\ntype: %s\nre: %s\npriority: %s\nrequires_ack: %s\ndeadline: %s\n' "$id" "$ME" "$to" "$type" "$re" "$priority" "$requires_ack" "$deadline"
    [[ -n "$SESSION" ]] && printf 'session: %s\n' "$SESSION"
    printf '%s\n%s\n' '---' "$body"
  } > "$tmp"
  # link(2) atomically claims the final name. A reader sees no file or a complete file.
  if ! ln "$tmp" "$final"; then rm -f "$tmp"; die "message ID collision: $final"; fi
  rm "$tmp"
  printf 'sent: %s\n' "$final"
  [[ "$priority" == now ]] && ring_doorbell "$to" "$type" "$slug"
  return 0
}

cmd_check() {
  local who="${1:-$ME}"; need_agent "$who"
  local inbox; inbox="$(message_path "$who")"
  [[ -d "$inbox" ]] || die "unknown agent: $who"
  local file count; count=$(find "$inbox" -maxdepth 1 -name '*.md' -type f | wc -l | tr -d ' ')
  printf '%s inbox: %s message(s)\n' "$who" "$count"
  for file in "$inbox"/*.md; do [[ -e "$file" ]] || break; printf '\n== %s ==\n' "$(basename "$file")"; cat "$file"; done
}

cmd_done() {
  need_me
  local message="${1:?usage: agent-bus done <id-or-file> --reply <reply-file>}"; shift
  [[ "${1:-}" == --reply ]] || die 'reply-first rule: pass --reply <reply-file>'
  local reply="${2:?missing reply file}"
  [[ -f "$reply" ]] || die "reply file not found: $reply"
  if [[ ! -f "$message" ]]; then message="$(message_path "$ME")/${message%.md}.md"; fi
  [[ -f "$message" ]] || die "message not found: $message"
  case "$message" in "$(message_path "$ME")"/*) ;; *) die 'can only archive messages from your own inbox';; esac
  local id from
  id="$(frontmatter_value "$message" id)"; from="$(frontmatter_value "$message" from)"
  [[ -n "$id" && -n "$from" ]] || die 'invalid inbound frontmatter'
  [[ "$(frontmatter_value "$reply" from)" == "$ME" ]] || die 'reply from does not match this agent'
  [[ "$(frontmatter_value "$reply" to)" == "$from" ]] || die 'reply to does not match original sender'
  [[ "$(frontmatter_value "$reply" re)" == "$id" ]] || die 'reply re does not match original message'
  mv "$message" "$BUS/$ME/processed/"
  printf 'archived: %s\n' "$(basename "$message")"
}

lock_name() { local p="$1"; printf '%s.lock' "$(printf '%s' "$p" | tr '[:upper:]' '[:lower:]' | tr '/' '-' | sed 's/^-//')"; }
cmd_lock() {
  need_me
  local target="${1:?usage: agent-bus lock <path>}"
  local lock="$BUS/locks/$(lock_name "$target")"
  mkdir -p "$BUS/locks"
  mkdir "$lock" 2>/dev/null || die "locked or being acquired: $lock"
  printf 'owner=%s%s taken=%s\n' "$ME" "${SESSION:+ session=$SESSION}" "$(now)" > "$lock/lease"
  printf 'locked: %s\n' "$lock"
}
cmd_unlock() {
  need_me
  local target="${1:?usage: agent-bus unlock <path>}"
  local lock="$BUS/locks/$(lock_name "$target")" lease="$BUS/locks/$(lock_name "$target")/lease"
  [[ -d "$lock" ]] || { printf 'no lock: %s\n' "$lock"; return; }
  [[ -f "$lease" ]] || die "invalid lock without lease: $lock"
  local owner; owner="$(sed -n 's/.*owner=\([^ ]*\).*/\1/p' "$lease")"
  [[ "$owner" == "$ME" ]] || die "lock is owned by $owner"
  rm "$lease" && rmdir "$lock"
  printf 'unlocked: %s\n' "$lock"
}
cmd_status() {
  need_me
  local state="${1:?usage: agent-bus status <working|idle|blocked>}" note="${2:-}"
  case "$state" in working|idle|blocked) ;; *) die 'invalid state';; esac
  mkdir -p "$BUS/$ME"
  printf 'state: %s\nsince: %s\nnotes: %s\n' "$state" "$(now)" "$note" > "$BUS/$ME/status.md"
}
case "${1:-}" in
  init) shift; cmd_init "$@";; send) shift; cmd_send "$@";; check) shift; cmd_check "$@";;
  done) shift; cmd_done "$@";; lock) shift; cmd_lock "$@";; unlock) shift; cmd_unlock "$@";;
  status) shift; cmd_status "$@";;
  *) printf 'usage: agent-bus {init|send|check|done|lock|unlock|status} ...\n' >&2; exit 2;;
esac
