#!/usr/bin/env bash
# letterbox — dependency-free helper for Agent Letterbox.
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_LINK_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_LINK_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
VERSION_FILE="$SCRIPT_DIR/../VERSION"
DEFAULT_DIR_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/agent-letterbox/default-dir"
if [[ -n "${LETTERBOX_DIR:-}" ]]; then
  BOX="$LETTERBOX_DIR"
elif [[ -f "$DEFAULT_DIR_FILE" ]]; then
  BOX="$(<"$DEFAULT_DIR_FILE")"
else
  BOX="$PWD/.letterbox"
fi
ME="${LETTERBOX_AGENT:-}"
SESSION="${LETTERBOX_SESSION:-}"

die() { printf 'letterbox: %s\n' "$*" >&2; exit 1; }
now() { date -u +%Y-%m-%dT%H:%M:%SZ; }
id_now() { date -u +%Y-%m-%dT%H%M%S; }
random_suffix() { od -An -N4 -tx4 /dev/urandom | tr -d '[:space:]'; }
need_me() { [[ "$ME" =~ ^[a-z][a-z0-9-]*$ ]] || die 'set LETTERBOX_AGENT to a lowercase agent name'; }
need_agent() { [[ "$1" =~ ^[a-z][a-z0-9-]*$ ]] || die "invalid agent name: $1"; }
inbox_path() { printf '%s/%s/inbox' "$BOX" "$1"; }
frontmatter_value() {
  awk -v wanted="$2" '
    NR == 1 && $0 == "---" { in_frontmatter = 1; next }
    in_frontmatter && $0 == "---" { exit }
    in_frontmatter {
      key = $0; sub(/:.*/, "", key)
      if (key == wanted) { value = $0; sub(/^[^:]*:[[:space:]]*/, "", value); print value; exit }
    }
  ' "$1"
}
canonical_dir() { (cd "$1" && pwd -P); }
tmux_registry_path() { printf '%s' "${LETTERBOX_TMUX_REGISTRY:-$BOX/tmux-agents.tsv}"; }
tmux_patterns_path() { printf '%s' "${LETTERBOX_TMUX_PATTERNS:-$BOX/tmux-patterns.tsv}"; }

# Current pane target when running inside tmux (precise doorbell injection).
tmux_current_target() {
  # Resolve the pane this process is running in. Prefer TMUX_PANE; otherwise
  # match pane_pid against this process or its ancestors (works headless).
  [[ -n "${TMUX:-}" ]] || return 1
  command -v tmux >/dev/null 2>&1 || return 1
  if [[ -n "${TMUX_PANE:-}" ]]; then
    printf '%s\n' "$TMUX_PANE"
    return 0
  fi
  local p=$$ candidates="" pane pid
  candidates=" $p "
  while [[ "$p" -gt 1 ]]; do
    p="$(ps -o ppid= -p "$p" 2>/dev/null | tr -d "[:space:]")"
    [[ -n "$p" ]] || break
    candidates+=" $p "
  done
  while read -r pane pid; do
    [[ -n "$pane" && -n "$pid" ]] || continue
    case "$candidates" in
      *" $pid "*) printf "%s\n" "$pane"; return 0;;
    esac
  done < <(tmux list-panes -a -F "#{pane_id} #{pane_pid}" 2>/dev/null)
  tmux display-message -p "#{pane_id}" 2>/dev/null
}

tmux_target_live() {
  local target="$1"
  [[ -n "$target" ]] || return 1
  command -v tmux >/dev/null 2>&1 || return 1
  # Pane id (%N) or session/window.pane name.
  if [[ "$target" == %* ]]; then
    tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -Fx "$target" >/dev/null
  else
    tmux has-session -t "$target" 2>/dev/null
  fi
}

cmd_tmux_register() {
  local agent="${1:?usage: letterbox tmux register <agent>}" registry target owner tmp session
  need_agent "$agent"
  command -v tmux >/dev/null 2>&1 || die 'tmux is unavailable'
  target="$(tmux_current_target)" || die 'run registration from inside a tmux pane (TMUX is unset)'
  [[ -n "$target" ]] || die 'could not resolve current tmux pane id'
  session="$(tmux display-message -p '#S' 2>/dev/null || true)"
  mkdir -p "$BOX/$agent/inbox" "$BOX/$agent/processed" "$BOX/locks"
  registry="$(tmux_registry_path)"
  mkdir -p "$(dirname "$registry")"
  if [[ -f "$registry" ]]; then
    owner="$(awk -F '\t' -v target="$target" '$2 == target { print $1; exit }' "$registry")"
    [[ -z "$owner" || "$owner" == "$agent" ]] || die "tmux target $target is already registered to $owner"
  fi
  tmp="$(mktemp "$(dirname "$registry")/.tmux-agents.tmp.XXXXXX")"
  [[ -f "$registry" ]] && awk -F '\t' -v agent="$agent" '$1 != agent { print }' "$registry" > "$tmp"
  # agent<TAB>pane_id<TAB>session_name<TAB>registered_at
  printf '%s\t%s\t%s\t%s\n' "$agent" "$target" "${session:-}" "$(now)" >> "$tmp"
  mv "$tmp" "$registry"
  printf 'registered: %s → %s (session %s)\n' "$agent" "$target" "${session:-(unknown)}"
}

cmd_tmux_status() {
  local registry="$(tmux_registry_path)"
  [[ -f "$registry" ]] || { printf 'no tmux registrations: %s\n' "$registry"; return; }
  printf 'agent\ttarget\tsession\tregistered_at\n'
  cat "$registry"
}

cmd_tmux_unregister() {
  local agent="${1:?usage: letterbox tmux unregister <agent>}" registry tmp
  need_agent "$agent"
  registry="$(tmux_registry_path)"
  [[ -f "$registry" ]] || { printf 'no tmux registration for %s\n' "$agent"; return; }
  tmp="$(mktemp "$(dirname "$registry")/.tmux-agents.tmp.XXXXXX")"
  awk -F '\t' -v agent="$agent" '$1 != agent { print }' "$registry" > "$tmp"
  mv "$tmp" "$registry"
  printf 'unregistered: %s\n' "$agent"
}

cmd_tmux_setup() {
  local agents='' setup_dir="$HOME/.agent-letterbox" submit=false
  local skill_source="$SCRIPT_DIR/../skills/agent-letterbox"
  local skills_dir="${LETTERBOX_SKILLS_DIR:-$HOME/.agents/skills}" skill_target
  local launcher_dir="${LETTERBOX_BIN_DIR:-$HOME/.local/bin}" launcher_target
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agents) agents="${2:?missing comma-separated agent list}"; shift;;
      --dir) setup_dir="${2:?missing directory}"; shift;;
      --submit|--automatic-doorbells) submit=true;;
      *) die "usage: letterbox tmux setup --agents pi,claude,grok,hermes [--dir <path>] [--automatic-doorbells]";;
    esac
    shift
  done
  [[ -n "$agents" ]] || die 'tmux setup requires --agents'
  command -v tmux >/dev/null 2>&1 || die 'tmux is unavailable'
  [[ -f "$skill_source/SKILL.md" ]] || die "bundled skill missing: $skill_source"
  local agent
  IFS=',' read -r -a agent_list <<< "$agents"
  for agent in "${agent_list[@]}"; do need_agent "$agent"; done

  BOX="$setup_dir"
  mkdir -p "$BOX" "$BOX/locks" "$(dirname "$DEFAULT_DIR_FILE")" "$launcher_dir"
  cmd_init "${agent_list[@]}" >/dev/null
  printf '%s\n' "$BOX" > "$DEFAULT_DIR_FILE"
  : > "$BOX/tmux-agents.tsv"
  if [[ ! -f "$BOX/tmux-patterns.tsv" ]]; then
    cat > "$BOX/tmux-patterns.tsv" <<'PAT'
# Optional static fallback: agent<TAB>tmux-session-name
# Live self-registration (letterbox tmux run/register) is preferred.
PAT
  fi
  mkdir -p "$skills_dir"
  skill_target="$skills_dir/agent-letterbox"
  launcher_target="$launcher_dir/letterbox"
  if [[ -e "$launcher_target" || -L "$launcher_target" ]]; then
    if [[ -L "$launcher_target" && "$(readlink "$launcher_target")" == "$SCRIPT_DIR/letterbox" ]]; then
      :
    else
      die "letterbox launcher already exists at $launcher_target; move it or set LETTERBOX_BIN_DIR"
    fi
  else
    ln -s "$SCRIPT_DIR/letterbox" "$launcher_target"
  fi
  if [[ -e "$skill_target" || -L "$skill_target" ]]; then
    if [[ -L "$skill_target" && "$(readlink "$skill_target")" == "$skill_source" ]]; then
      :
    else
      die "agent-letterbox skill already exists at $skill_target; move it or set LETTERBOX_SKILLS_DIR"
    fi
  else
    ln -s "$skill_source" "$skill_target"
  fi
  cat > "$BOX/env.sh" <<EOF
# Generated by: letterbox tmux setup
export LETTERBOX_DIR='$BOX'
export LETTERBOX_DOORBELL='$SCRIPT_DIR/../adapters/tmux.sh'
export LETTERBOX_TMUX_REGISTRY='$BOX/tmux-agents.tsv'
export LETTERBOX_TMUX_PATTERNS='$BOX/tmux-patterns.tsv'
export AGENT_LETTERBOX_SKILL='$skill_target'
EOF
  [[ "$submit" == true ]] && printf 'export LETTERBOX_TMUX_SUBMIT=1\n' >> "$BOX/env.sh"
  cat > "$BOX/AGENT-LETTERBOX.md" <<'EOF'
# Agent Letterbox startup rule (tmux)

The shared Agent Letterbox skill is installed at `~/.agents/skills/agent-letterbox`
(or the configured `LETTERBOX_SKILLS_DIR`). Ensure your agent runtime loads global Agent Skills.

You control your own tmux layout. Launch each agent inside the pane you choose:

```bash
source ~/.agent-letterbox/env.sh   # or your LETTERBOX_DIR/env.sh
letterbox tmux run <your-agent-id> -- <agent-command>
```

That registers the current pane for live doorbells, then starts the agent.

At resume, if the pane id changed:

```bash
letterbox tmux register <your-agent-id>
letterbox check
```

For actionable letters, use `letterbox reply` with body text piped on stdin.
Use `--now` on a reply only when the original letter priority is `now`.
EOF
  printf 'tmux team ready: %s\n' "$BOX"
  printf 'Letterbox launcher linked: %s\n' "$launcher_target"
  printf 'Agent Letterbox skill linked: %s\n' "$skill_target"
  printf 'Source the environment:\n  source %s/env.sh\n' "$BOX"
  printf 'In each agent pane, launch with:\n'
  printf '  letterbox tmux run <agent-id> -- <agent-command>\n'
  [[ "$submit" == true ]] || printf 'Automatic input is off. Re-run with --automatic-doorbells to enable it.\n'
}

cmd_tmux_run() {
  local agent="${1:?usage: letterbox tmux run <agent> -- <command...>}"; shift
  need_agent "$agent"
  [[ "${1:-}" == -- ]] || die 'tmux run requires -- before the agent command'
  shift
  [[ $# -gt 0 ]] || die 'tmux run requires an agent command'
  [[ -f "$BOX/env.sh" ]] && # shellcheck disable=SC1090
    source "$BOX/env.sh"
  BOX="${LETTERBOX_DIR:-$BOX}"
  export LETTERBOX_DIR="$BOX" LETTERBOX_AGENT="$agent"
  cmd_tmux_register "$agent"
  exec "$@"
}

cmd_tmux() {
  case "${1:-}" in
    setup) shift; cmd_tmux_setup "$@";;
    run) shift; cmd_tmux_run "$@";;
    register) shift; cmd_tmux_register "$@";;
    unregister) shift; cmd_tmux_unregister "$@";;
    status) shift; cmd_tmux_status "$@";;
    *) die 'usage: letterbox tmux {setup|run|register|unregister|status} ...';;
  esac
}

cmd_version() {
  [[ -f "$VERSION_FILE" ]] || die "version file not found: $VERSION_FILE"
  printf 'letterbox %s\n' "$(<"$VERSION_FILE")"
}

cmd_init() {
  [[ $# -gt 0 ]] || die 'usage: letterbox init <agent> [agent...]'
  mkdir -p "$BOX/locks"
  local agent
  for agent in "$@"; do
    need_agent "$agent"
    mkdir -p "$BOX/$agent/inbox" "$BOX/$agent/processed"
  done
  printf 'initialized letterbox: %s\n' "$BOX"
}

ring_doorbell() {
  local to="$1" type="$2" slug="$3"
  [[ -n "${LETTERBOX_DOORBELL:-}" ]] || return 0
  [[ -x "$LETTERBOX_DOORBELL" ]] || die "doorbell is not executable: $LETTERBOX_DOORBELL"
  "$LETTERBOX_DOORBELL" "$to" "$type" "$slug"
}

publish_message() { # to type slug priority requires_ack re deadline body
  local to="$1" type="$2" slug="$3" priority="$4" requires_ack="$5" re="$6" deadline="$7" body="$8"
  local id="$(id_now)-$ME-$type-$slug-$(random_suffix)"
  local inbox; inbox="$(inbox_path "$to")"
  local final="$inbox/$id.md" tmp
  tmp="$(mktemp "$inbox/.${id}.tmp.XXXXXX")" || die 'cannot create temporary message'
  {
    printf '%s\n' '---'
    printf 'id: %s\nfrom: %s\nto: %s\ntype: %s\nre: %s\npriority: %s\nrequires_ack: %s\ndeadline: %s\n' "$id" "$ME" "$to" "$type" "$re" "$priority" "$requires_ack" "$deadline"
    [[ -n "$SESSION" ]] && printf 'session: %s\n' "$SESSION"
    printf '%s\n%s\n' '---' "$body"
  } > "$tmp"
  # link(2) atomically claims the final name. Readers see no file or a complete file.
  if ! ln "$tmp" "$final"; then rm -f "$tmp"; die "message ID collision: $final"; fi
  rm "$tmp"
  printf '%s\n' "$final"
}

cmd_send() {
  need_me
  local to="${1:?usage: letterbox send <to> <type> <slug> [--now] [--ack] [--re <id>] [--deadline <UTC>]}"
  local type="${2:?missing type}" slug="${3:?missing slug}"; shift 3
  need_agent "$to"
  [[ -d "$(inbox_path "$to")" ]] || die "unknown recipient: $to (run init first)"
  case "$type" in request|delegate|status|blocker|result|ack|nack|info) ;; *) die "invalid message type: $type";; esac
  slug="$(printf '%s' "$slug" | tr '[:upper:] ' '[:lower:]-' | tr -cd 'a-z0-9-')"
  [[ -n "$slug" ]] || die 'slug became empty'
  local priority=next requires_ack=false re='' deadline=''
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --now) priority=now;; --ack) requires_ack=true;;
      --re) re="${2:?missing reply id}"; shift;;
      --deadline) deadline="${2:?missing deadline}"; shift;;
      *) die "unknown option: $1";;
    esac
    shift
  done
  local body; body="$(cat)"
  [[ -n "$body" ]] || die 'empty message body'
  local final; final="$(publish_message "$to" "$type" "$slug" "$priority" "$requires_ack" "$re" "$deadline" "$body")"
  printf 'sent: %s\n' "$final"
  [[ "$priority" == now ]] && ring_doorbell "$to" "$type" "$slug"
  return 0
}

cmd_check() {
  local who="${1:-$ME}"; need_agent "$who"
  local inbox; inbox="$(inbox_path "$who")"
  [[ -d "$inbox" ]] || die "unknown agent: $who"
  local file count; count=$(find "$inbox" -maxdepth 1 -name '*.md' -type f | wc -l | tr -d ' ')
  printf '%s inbox: %s message(s)\n' "$who" "$count"
  for file in "$inbox"/*.md; do [[ -e "$file" ]] || break; printf '\n== %s ==\n' "$(basename "$file")"; cat "$file"; done
}

resolve_own_inbox_message() {
  local message="$1"
  if [[ ! -f "$message" ]]; then message="$(inbox_path "$ME")/${message%.md}.md"; fi
  [[ -f "$message" ]] || die "message not found: $message"
  case "$message" in "$(inbox_path "$ME")"/*) printf '%s\n' "$message";; *) die 'can only handle messages from your own inbox';; esac
}

archive_message() {
  local message="$1"
  mv "$message" "$BOX/$ME/processed/"
  printf 'archived: %s\n' "$(basename "$message")"
}

cmd_reply() {
  need_me
  local message="${1:?usage: letterbox reply <id-or-file> <ack|nack|result> <slug> [--now]}"
  local type="${2:?missing reply type}" slug="${3:?missing reply slug}"; shift 3
  case "$type" in ack|nack|result) ;; *) die 'reply type must be ack, nack, or result';; esac
  local priority=next
  [[ "${1:-}" == --now ]] && priority=now
  [[ $# -le 1 ]] || die "unknown option: ${2:-}"
  message="$(resolve_own_inbox_message "$message")"
  local original_id original_from body final
  original_id="$(frontmatter_value "$message" id)"; original_from="$(frontmatter_value "$message" from)"
  [[ -n "$original_id" && -n "$original_from" ]] || die 'invalid inbound frontmatter'
  [[ -d "$(inbox_path "$original_from")" ]] || die "original sender has no inbox: $original_from"
  body="$(cat)"; [[ -n "$body" ]] || die 'empty reply body'
  slug="$(printf '%s' "$slug" | tr '[:upper:] ' '[:lower:]-' | tr -cd 'a-z0-9-')"
  [[ -n "$slug" ]] || die 'slug became empty'
  final="$(publish_message "$original_from" "$type" "$slug" "$priority" false "$original_id" '' "$body")"
  printf 'replied: %s\n' "$final"
  [[ "$priority" == now ]] && ring_doorbell "$original_from" "$type" "$slug"
  archive_message "$message"
}

cmd_done() {
  need_me
  local message="${1:?usage: letterbox done <id-or-file> --reply <delivered-reply-file>}"; shift
  [[ "${1:-}" == --reply ]] || die 'use letterbox reply for normal replies, or pass --reply <delivered-reply-file>'
  local reply="${2:?missing reply file}"
  [[ -f "$reply" ]] || die "reply file not found: $reply"
  message="$(resolve_own_inbox_message "$message")"
  local id from expected_dir actual_dir
  id="$(frontmatter_value "$message" id)"; from="$(frontmatter_value "$message" from)"
  [[ -n "$id" && -n "$from" ]] || die 'invalid inbound frontmatter'
  expected_dir="$(canonical_dir "$(inbox_path "$from")")"
  actual_dir="$(canonical_dir "$(dirname "$reply")")"
  [[ "$actual_dir" == "$expected_dir" ]] || die "reply must be delivered in $expected_dir before archiving"
  [[ "$(frontmatter_value "$reply" from)" == "$ME" ]] || die 'reply from does not match this agent'
  [[ "$(frontmatter_value "$reply" to)" == "$from" ]] || die 'reply to does not match original sender'
  [[ "$(frontmatter_value "$reply" re)" == "$id" ]] || die 'reply re does not match original message'
  archive_message "$message"
}

lock_name() {
  # Escape literal hyphens before encoding slashes so `sub/file` and
  # `sub-file` always produce distinct advisory lock paths.
  local p
  p="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  p="${p//-/--}"
  p="${p//\//-slash-}"
  printf '%s.lock' "$p"
}
cmd_lock() {
  need_me
  local target="${1:?usage: letterbox lock <path>}" lock="$BOX/locks/$(lock_name "${1:?}")"
  mkdir -p "$BOX/locks"
  mkdir "$lock" 2>/dev/null || die "locked or being acquired: $lock"
  printf 'owner=%s%s taken=%s\n' "$ME" "${SESSION:+ session=$SESSION}" "$(now)" > "$lock/lease"
  printf 'locked: %s\n' "$lock"
}
cmd_unlock() {
  need_me
  local target="${1:?usage: letterbox unlock <path>}" lock="$BOX/locks/$(lock_name "${1:?}")"
  local lease="$lock/lease"
  [[ -d "$lock" ]] || { printf 'no lock: %s\n' "$lock"; return; }
  [[ -f "$lease" ]] || die "invalid lock without lease: $lock"
  local owner; owner="$(sed -n 's/.*owner=\([^ ]*\).*/\1/p' "$lease")"
  [[ "$owner" == "$ME" ]] || die "lock is owned by $owner"
  rm "$lease" && rmdir "$lock"
  printf 'unlocked: %s\n' "$lock"
}
cmd_status() {
  need_me
  local state="${1:?usage: letterbox status <working|idle|blocked>}" note="${2:-}"
  case "$state" in working|idle|blocked) ;; *) die 'invalid state';; esac
  mkdir -p "$BOX/$ME"
  printf 'state: %s\nsince: %s\nnotes: %s\n' "$state" "$(now)" "$note" > "$BOX/$ME/status.md"
}
case "${1:-}" in
  --version|-V|version) cmd_version;;
  init) shift; cmd_init "$@";; send) shift; cmd_send "$@";; check) shift; cmd_check "$@";;
  reply) shift; cmd_reply "$@";; done) shift; cmd_done "$@";; lock) shift; cmd_lock "$@";; unlock) shift; cmd_unlock "$@";;
  status) shift; cmd_status "$@";; tmux) shift; cmd_tmux "$@";;
  *) printf 'usage: letterbox {init|send|check|reply|done|lock|unlock|status|tmux|--version} ...\n\ntmux: setup | run | register | unregister | status\n' >&2; exit 2;;
esac
